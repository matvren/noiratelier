# Server
PORT=3000

# Secret used to sign login sessions. Change this to a long random string.
JWT_SECRET=change_me_to_a_long_random_string_1234567890

# The ONLY account that gets owner/admin powers (editing prices, products, etc.)
OWNER_EMAIL=numbell98@gmail.com

# The base URL used in emails / redirects
BASE_URL=http://localhost:3000
